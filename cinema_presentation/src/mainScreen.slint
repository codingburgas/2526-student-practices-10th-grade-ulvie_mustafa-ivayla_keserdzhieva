import { StandardButton, LineEdit, ComboBox, ListView, VerticalBox, HorizontalBox, GridBox } from "std-widgets.slint";

export component MainScreen inherits Window {
    width: 1440px;
    height: 943px;
    title: "Test Screen - Cinema Booking System";
    background: #151515;

    // Grid overlay for reference (optional)
    Rectangle {
        width: 100%;
        height: 100%;
        background: transparent;

        // Subtle grid lines
        for i in 0..14: Rectangle {
            x: i * 100px;
            y: 0px;
            width: 1px;
            height: 100%;
            background: rgba(100, 100, 100, 0.1);
        }

        for i in 0..9: Rectangle {
            x: 0px;
            y: i * 100px;
            width: 100%;
            height: 1px;
            background: rgba(100, 100, 100, 0.1);
        }
    }

    // Header with screen info
    Rectangle {
        x: 0px;
        y: 0px;
        width: 100%;
        height: 80px;
        background: linear-gradient(to bottom, #1a1a1a, #151515);

        VerticalBox {
            padding: 20px;
            spacing: 5px;

            Text {
                text: "Cinema Ticket Booking System - Test Screen";
                color: white;
                font-size: 24px;
                font-weight: bold;
            }

            Text {
                text: "Resolution: 1440px × 943px | Background: #151515";
                color: #888;
                font-size: 12px;
            }
        }
    }

    // Main content area
    Rectangle {
        x: 0px;
        y: 80px;
        width: 100%;
        height: 100% - 80px;
        background: transparent;

        VerticalBox {
            alignment: center;
            spacing: 20px;

            // Center content
            Rectangle {
                width: 400px;
                height: 200px;
                background: rgba(255, 255, 255, 0.05);
                border-radius: 8px;
                border-width: 1px;
                border-color: #333;

                VerticalBox {
                    alignment: center;
                    padding: 30px;
                    spacing: 15px;

                    Text {
                        text: "🎬 Test Screen Ready";
                        color: #888;
                        font-size: 28px;
                        font-weight: bold;
                        text-alignment: center;
                    }

                    Text {
                        text: "This is your Slint test screen with exact specifications:\n• Background: #151515\n• Width: 1440px\n• Height: 943px";
                        color: #666;
                        font-size: 14px;
                        text-alignment: center;
                        line-height: 1.4;
                    }

                    Text {
                        text: "Grid overlay visible for alignment reference";
                        color: #444;
                        font-size: 12px;
                        text-alignment: center;
                    }
                }
            }

            // Control buttons
            HorizontalBox {
                spacing: 15px;

                StandardButton {
                    text: "Toggle Grid";
                    clicked => {
                        // Grid is always visible in this version
                        // Could be enhanced with state management
                    }
                }

                StandardButton {
                    text: "Close";
                    clicked => {
                        // Close the window
                        root.visible = false;
                    }
                }
            }
        }
    }

    // Dimension indicators (corners)
    Text {
        x: 20px;
        y: 20px;
        text: "1440×943";
        color: #555;
        font-size: 11px;
        font-family: "Courier New";
    }

    Text {
        x: 1440px - 100px;
        y: 20px;
        text: "W:1440";
        color: #555;
        font-size: 11px;
        font-family: "Courier New";
    }

    Text {
        x: 20px;
        y: 943px - 40px;
        text: "H:943";
        color: #555;
        font-size: 11px;
        font-family: "Courier New";
    }

    Text {
        x: 1440px - 100px;
        y: 943px - 40px;
        text: "943px";
        color: #555;
        font-size: 11px;
        font-family: "Courier New";
    }

    // Info panel (top-right)
    Rectangle {
        x: 1440px - 250px;
        y: 20px;
        width: 220px;
        height: 60px;
        background: rgba(0, 0, 0, 0.5);
        border-radius: 4px;
        border-width: 1px;
        border-color: #333;

        VerticalBox {
            padding: 10px;
            spacing: 2px;

            Text {
                text: "Test Screen Info";
                color: #888;
                font-size: 11px;
                font-weight: bold;
            }

            Text {
                text: "Resolution: 1440 × 943";
                color: #666;
                font-size: 10px;
                font-family: "Courier New";
            }

            Text {
                text: "Background: #151515";
                color: #666;
                font-size: 10px;
                font-family: "Courier New";
            }
        }
    }
}
